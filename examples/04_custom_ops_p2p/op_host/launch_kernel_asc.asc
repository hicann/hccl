#include "aicpu_api.h"
#include "common.h"

#ifdef __cplusplus
extern "C" {
#endif

// 声明 ASC 内核函数
extern __global__ __aicpu__ uint32_t HcclP2PAicpuKernelAsc(void *args);

#ifdef __cplusplus
}
#endif

namespace ops_hccl_p2p {

// 使用 ASC 编译的包装函数，支持 <<<>>> 语法
HcclResult LaunchKernelBinary(OpParam &param, aclrtStream stream)
{
    // 使用二进制 <<<>>> 调用方式
    HCCL_INFO("[BINARY_MODE] Launching kernel with <<<>>> syntax in ASC compiled code");
    constexpr uint32_t blockDim = 1;
    HcclP2PAicpuKernelAsc<<<blockDim, nullptr, stream>>>(&param, sizeof(OpParam));
    
    // 检查内核启动错误
    aclError aclRet = aclrtGetLastError(ACL_RT_THREAD_LEVEL);
    if (aclRet != ACL_SUCCESS) {
        HCCL_ERROR("[BINARY_MODE] Kernel launch failed with <<<>>> syntax, ret[%d]", aclRet);
        return HCCL_E_INTERNAL;
    }
    
    HCCL_INFO("[BINARY_MODE] Kernel launched successfully with <<<>>> syntax");
    return HCCL_SUCCESS;
}

}
